generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model log_types {
  id         BigInt     @id @default(autoincrement())
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  messages   messages[]

  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model message_types {
  id           BigInt     @id @default(autoincrement())
  message_type String     @db.VarChar
  messages     messages[]

  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model messages {
  id           BigInt   @id @default(autoincrement())
  from_number  String   @db.VarChar
  to_number    String   @db.VarChar
  message      String
  message_type BigInt   @db.BigInt
  pharmacy_id  BigInt?  @db.BigInt
  status_code  Int
  log_type     BigInt   @db.BigInt
  log_error    String   @db.VarChar()
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  message_types message_types @relation(fields: [message_type], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pharmacies    pharmacies?   @relation(fields: [pharmacy_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  log_types     log_types     @relation(fields: [log_type], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model pharmacies {
  id               BigInt     @id @default(autoincrement())
  pharmacy_name    String     @db.VarChar
  //pharmacy_mobile  String     @db.VarChar
  pharmacy_address String     @db.VarChar
  created_at       DateTime   @default(now()) @db.Timestamptz(6)
  //password         String?
  messages         messages[]
  users            users[]

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
// model system_logs {
//   id BigInt @id @default(autoincrement())

//   @@schema("public")
// }

model user_roles {
  id        BigInt  @id @default(autoincrement())
  role_name String  @db.VarChar
  users     users[]

  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id            BigInt     @id @default(autoincrement())
  username      String     @db.VarChar(50)
  password      String     @db.VarChar(50)
  mobile        String     @unique @db.VarChar(13)
  role_id       BigInt     @db.BigInt
  pharmacy_id   BigInt     @db.BigInt
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  is_logging_in Boolean    @default(false) @db.Boolean
  is_active     Boolean?   @default(true)
  pharmacies    pharmacies @relation(fields: [pharmacy_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_roles    user_roles @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}
